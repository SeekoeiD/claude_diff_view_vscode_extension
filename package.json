{
  "name": "ai-cli-diff-view",
  "displayName": "Out-of-band diffs",
  "description": "Inline diff review for out-of-band file edits in VS Code (any external writer; optional Claude Code session launcher)",
  "version": "1.0.9",
  "publisher": "SeekoeiD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeekoeiD/out-of-band-diffs-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/SeekoeiD/out-of-band-diffs-vscode-extension/issues"
  },
  "homepage": "https://github.com/SeekoeiD/out-of-band-diffs-vscode-extension#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "editorInsets"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-cli-diff-view",
          "title": "AI CLI diff view",
          "icon": "media/claude-icon.svg"
        }
      ]
    },
    "views": {
      "ai-cli-diff-view": [
        {
          "id": "ai-cli-diff-view.session",
          "name": "Session",
          "type": "webview"
        }
      ],
      "explorer": [
        {
          "id": "ai-cli-diff-view.navBar",
          "name": "AI CLI Diff",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-cli-diff-view.startSession",
        "title": "AI CLI Diff: Start Claude Session"
      },
      {
        "command": "ai-cli-diff-view.acceptAllHunks",
        "title": "AI CLI Diff: Accept All Changes"
      },
      {
        "command": "ai-cli-diff-view.acceptAllChanges",
        "title": "AI CLI Diff: Accept All Changes (All Files)"
      },
      {
        "command": "ai-cli-diff-view.revertAllHunks",
        "title": "AI CLI Diff: Revert All Changes"
      },
      {
        "command": "ai-cli-diff-view.revertAllChanges",
        "title": "AI CLI Diff: Revert All Changes (All Files)"
      },
      {
        "command": "ai-cli-diff-view.acceptHunk",
        "title": "AI CLI Diff: Accept Hunk"
      },
      {
        "command": "ai-cli-diff-view.revertHunk",
        "title": "AI CLI Diff: Revert Hunk"
      },
      {
        "command": "ai-cli-diff-view.openPendingFile",
        "title": "AI CLI Diff: Open Pending File"
      },
      {
        "command": "ai-cli-diff-view.nextFile",
        "title": "AI CLI Diff: Next Edited File"
      },
      {
        "command": "ai-cli-diff-view.prevFile",
        "title": "AI CLI Diff: Previous Edited File"
      }
    ],
    "keybindings": [
      {
        "command": "ai-cli-diff-view.startSession",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "ai-cli-diff-view.acceptAllHunks",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      },
      {
        "command": "ai-cli-diff-view.revertAllHunks",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z"
      },
      {
        "command": "ai-cli-diff-view.prevFile",
        "key": "alt+h",
        "when": "ai-cli-diff-view.hasPendingDiff"
      },
      {
        "command": "ai-cli-diff-view.nextFile",
        "key": "alt+l",
        "when": "ai-cli-diff-view.hasPendingDiff"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ai-cli-diff-view.acceptAllHunks",
          "when": "ai-cli-diff-view.hasPendingDiff",
          "group": "navigation@1"
        },
        {
          "command": "ai-cli-diff-view.revertAllHunks",
          "when": "ai-cli-diff-view.hasPendingDiff",
          "group": "navigation@2"
        }
      ]
    },
    "colors": [
      {
        "id": "aiCliDiffView.pendingFileForeground",
        "description": "Color of files and ancestor folders that contain an AI CLI Diff pending change.",
        "defaults": {
          "dark": "#3794FF",
          "light": "#0066BF",
          "highContrast": "#3794FF"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "material-icon-theme": "^5.32.0"
  }
}
